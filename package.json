{
  "name": "sanctuary-builder",
  "version": "1.0.0",
  "description": "Sanctuary Builder — Church Website Platform",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "render-build": "cd client && npm install && npm run build",
    "seed": "node server/seed/seed.js",
    "start": "node server/index.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "concurrently": "^8.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "nodemailer": "^8.0.3",
    "nodemon": "^3.0.2",
    "stripe": "^20.4.1",
    "@vitejs/plugin-react": "^4.2.0",
    "vite": "^5.0.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "axios": "^1.6.2"
  },
  "devDependencies": {
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15"
  }
}
